# =============================================================================
# SRE Edge Relay — Customer Configuration
# =============================================================================
# Copy this to .env and fill in your values:  cp .env.example .env

# --- 1. Connection to SaaS Platform ---
# Get this token from the SaaS dashboard after creating a cluster
CLUSTER_TOKEN=cl_your_token_here
SAAS_URL=https://your-sre-platform.example.com

# --- 2. Your Monitoring Stack ---
# Point these at your existing Prometheus and Loki instances
PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100

# --- 3. Your GitHub (for code context & revert PRs) ---
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-org/your-repo

# --- 4. Local runbooks source of truth ---
# Runbooks live in the repository root `runbooks/` folder and are mounted into the local runbooks MCP server.
